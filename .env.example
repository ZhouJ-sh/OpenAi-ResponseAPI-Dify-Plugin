# 复制为 .env 后供 `bash scripts/debug.sh` 使用。
# 当前插件首版仅对接 OpenAI 兼容的 /v1/responses 调试语义。
# 不支持 /v1/chat/completions 或 /v1/messages。

# 调试安装到 Dify 所需变量。
INSTALL_METHOD=remote
REMOTE_INSTALL_URL=debug.dify.ai:5003
REMOTE_INSTALL_KEY=********-****-****-****-************

# 执行 `bash scripts/e2e.sh` 时可复用以下变量。
API_BASE_URL=http://127.0.0.1:8080/v1
API_KEY=sk-example
MODEL_NAME=gpt-5.4
